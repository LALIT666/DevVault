// 📌 CONCEPT: Prisma Schema - Database structure definition
// 📌 Models = Tables in database
// 📌 Relations = Foreign keys

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  // 📌 Reads from .env
}

// 📌 CONCEPT: User Model (for authentication)
model User {
  id            String    @id @default(cuid())  // 📌 Primary key, auto-generated
  name          String?
  email         String    @unique  // 📌 Unique constraint
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 📌 CONCEPT: Relations (one-to-many)
  bookmarks     Bookmark[]
  snippets      Snippet[]
  collections   Collection[]
  accounts      Account[]
  sessions      Session[]
  
  @@map("users")  // 📌 Table name in database
}

// 📌 CONCEPT: Bookmark Model
model Bookmark {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  tags        String[]  // 📌 Array of strings (PostgreSQL specific)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 📌 CONCEPT: Foreign Key Relation
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
  
  @@map("bookmarks")
}

// 📌 CONCEPT: Snippet Model
model Snippet {
  id          String   @id @default(cuid())
  title       String
  code        String   @db.Text  // 📌 Large text field
  language    String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
  
  @@map("snippets")
}

// 📌 CONCEPT: Collection Model (folders for organizing)
model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookmarks   Bookmark[]
  snippets    Snippet[]
  
  @@map("collections")
}

// 📌 CONCEPT: NextAuth models (for authentication)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}